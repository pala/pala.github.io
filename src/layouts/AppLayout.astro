---
import BaseLayout from './BaseLayout.astro';

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <style>
    :global(.image-row) {
      display: flex;
      justify-content: space-around;
      flex-wrap: wrap;
    }
    :global(.image-row img) {
      flex: 1 1 auto;
      width: 20%;
      max-width: 100%;
      height: auto;
      margin: 10px;
    }
  </style>

  <slot />
</BaseLayout>
