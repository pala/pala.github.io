---
import BaseLayout from './BaseLayout.astro';
import GallerySlideshow from '../components/GallerySlideshow.astro';

const { title, date, images = [] } = Astro.props;
---

<BaseLayout title={title}>
  <style>
    /* Hide all images that are direct children of post-content (Markdown rendered) */
    .post-content > :global(p) > :global(img),
    .post-content > :global(img) {
      display: none !important;
    }

    .navigation {
      color: var(--meta-color);
      font-size: 12px;
      margin-top: 40px;
      border-top: 1px solid var(--border-color);
      padding-top: 20px;
    }
    .post-header {
      margin-bottom: 20px;
    }
    .post-meta {
      color: var(--meta-color);
      font-size: 14px;
    }
    .wrapper {
      max-width: 1000px; /* Slightly wider for the slideshow */
    }
  </style>

  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {date && (
        <p class="post-meta">
          <time datetime={date.toISOString()}>
            {date.toISOString().split('T')[0]}
          </time>
        </p>
      )}
    </header>

    <div class="post-content">
      <slot /> <!-- This will still render text/descriptions -->
      <GallerySlideshow images={images} />
    </div>

    <div class="navigation">
      <a href="/">Back to Home</a>
    </div>
  </article>
</BaseLayout>
