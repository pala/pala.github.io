---
import BaseLayout from './BaseLayout.astro';

const { title, date, prev, next } = Astro.props;
---

<BaseLayout title={title}>
  <style>
    #post-header h3,
    #post-header p {
      display: inline;
      vertical-align: bottom;
    }
    .post-meta {
      float: right;
    }
    .post-navigation {
      margin-top: 30px;
      display: flex;
      justify-content: space-between;
    }
  </style>

  <article class="post">
    <header class="post-header" id="post-header">
      <h3>{title}</h3>
      <p class="post-meta">
        <time datetime={date ? date.toISOString() : ''}>
          {date ? date.toISOString().split('T')[0] : ''}
        </time>
      </p>
    </header>

    <div class="post-content">
      <slot />
    </div>

    <div class="post-navigation">
      <div>
        {prev && <a href={prev.url}>&lt; {prev.title}</a>}
      </div>
      <div>
        {next && <a href={next.url}>{next.title} &gt;</a>}
      </div>
    </div>
  </article>
</BaseLayout>
