---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostLayout from '../layouts/PostLayout.astro';
import GalleryLayout from '../layouts/GalleryLayout.astro';
import AppLayout from '../layouts/AppLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  
  // Sort posts by date ascending
  const sortedPosts = posts.sort((a, b) => {
    const dateA = a.data.date || new Date(a.id.slice(0, 10));
    const dateB = b.data.date || new Date(b.id.slice(0, 10));
    return dateA.valueOf() - dateB.valueOf();
  });

  return sortedPosts.map((post) => {
    // With glob loader, id is the filename without extension e.g. "YYYY-MM-DD-title"
    const match = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
    let year = '1970', month = '01', day = '01', titleSlug = post.id;
    
    if (match) {
      year = match[1];
      month = match[2];
      day = match[3];
      titleSlug = match[4];
    }
    
    const category = post.data.categories ? post.data.categories.toLowerCase() : '';
    const generatedSlug = category 
      ? `${category}/${year}/${month}/${day}/${titleSlug}`
      : `${year}/${month}/${day}/${titleSlug}`;

    const sameCategoryPosts = sortedPosts.filter(p => p.data.categories === post.data.categories);
    const currentIndex = sameCategoryPosts.findIndex(p => p.id === post.id);
    
    const prevPost = currentIndex > 0 ? sameCategoryPosts[currentIndex - 1] : null;
    const nextPost = currentIndex < sameCategoryPosts.length - 1 ? sameCategoryPosts[currentIndex + 1] : null;

    const getPostUrl = (p) => {
      const pMatch = p.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
      if (!pMatch) return `/${p.id}.html`;
      const c = p.data.categories ? p.data.categories.toLowerCase() : '';
      return c 
        ? `/${c}/${pMatch[1]}/${pMatch[2]}/${pMatch[3]}/${pMatch[4]}.html`
        : `/${pMatch[1]}/${pMatch[2]}/${pMatch[3]}/${pMatch[4]}.html`;
    };

    return {
      params: { slug: generatedSlug },
      props: {
        post,
        prev: prevPost ? { title: prevPost.data.title || prevPost.id, url: getPostUrl(prevPost) } : null,
        next: nextPost ? { title: nextPost.data.title || nextPost.id, url: getPostUrl(nextPost) } : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

// Pick layout
const layout = post.data.layout || 'post';
---

{layout === 'gallery' ? (
  <GalleryLayout title={post.data.title} date={post.data.date} prev={prev} next={next}>
    <Content />
  </GalleryLayout>
) : layout === 'app' ? (
  <AppLayout title={post.data.title} date={post.data.date}>
    <Content />
  </AppLayout>
) : (
  <PostLayout title={post.data.title} date={post.data.date} prev={prev} next={next}>
    <Content />
  </PostLayout>
)}
