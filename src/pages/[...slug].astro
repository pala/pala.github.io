---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import GalleryLayout from '../layouts/GalleryLayout.astro';
import AppLayout from '../layouts/AppLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const galleries = await getCollection('galleries');
  
  // Dated Post Paths
  const postPaths = posts.map((post) => {
    const match = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
    const year = match ? match[1] : '1970';
    const titleSlug = match ? match[4] : post.id;
    const generatedSlug = `${year}/${titleSlug}`;

    return {
      params: { slug: generatedSlug },
      props: { entry: post, type: 'post' },
    };
  });

  // Themed Gallery Paths (No Date)
  const galleryPaths = galleries.map((gallery) => {
    return {
      params: { slug: gallery.id },
      props: { entry: gallery, type: 'gallery' },
    };
  });

  return [...postPaths, ...galleryPaths];
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Extract images from markdown body for the grid
const imageRegex = /!\[.*?\]\((.*?)\)/g;
const images = [];
let match;
while ((match = imageRegex.exec(entry.body)) !== null) {
  images.push(match[1]);
}

const layout = entry.data.layout || 'post';
const title = entry.data.title;
const date = entry.data.date;
---

{layout === 'gallery' ? (
  <GalleryLayout title={title} date={date} images={images}>
    <Content />
  </GalleryLayout>
) : layout === 'app' ? (
  <AppLayout title={title} date={date}>
    <Content />
  </AppLayout>
) : (
  <PostLayout title={title} date={date}>
    <Content />
  </PostLayout>
)}
