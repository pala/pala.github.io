---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts');

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date || new Date(a.id.slice(0, 10));
  const dateB = b.data.date || new Date(b.id.slice(0, 10));
  return dateB.valueOf() - dateA.valueOf();
});

const getPostUrl = (p) => {
  // With glob loader, id is the filename without extension e.g. "YYYY-MM-DD-title"
  const match = p.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
  if (!match) return `/${p.id}`;
  
  return `/${match[1]}/${match[4]}`;
};
---

<BaseLayout title="Posts">
  <div class="posts-list">
    <header class="post-header">
      <h1 class="post-title">Posts</h1>
    </header>

    <ul class="posts-ul">
      {sortedPosts.map(post => (
        <li>
          <a href={getPostUrl(post)} class="post-link">
            {post.data.title || post.id}
          </a>
          <time datetime={post.data.date ? post.data.date.toISOString() : post.id.slice(0, 10)} class="post-date">
            {post.data.date ? post.data.date.toISOString().split('T')[0] : post.id.slice(0, 10)}
          </time>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .posts-ul {
    list-style: none;
    padding: 0;
  }
  .posts-ul li {
    margin-bottom: 20px;
    border-bottom: 1px solid #f2f2f2;
    padding-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .post-link {
    font-size: 18px;
  }
  .post-date {
    color: #828282;
    font-size: 14px;
  }
</style>
