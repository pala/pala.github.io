---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// 1. Get all galleries
const galleries = await getCollection('galleries');

// 2. Extract all image paths from markdown bodies
// These are now absolute paths like /assets/posts/...
const imageUrls = galleries.flatMap(gallery => {
  if (!gallery.body) return [];
  const imageRegex = /!\[.*?\]\((.*?)\)/g;
  const paths = [];
  let match;
  while ((match = imageRegex.exec(gallery.body)) !== null) {
    paths.push(match[1]);
  }
  return paths;
}).filter(url => url.startsWith('/assets/'));

const galleriesUrl = '/galleries';
---

<BaseLayout>
  <div class="home">
    <a href={galleriesUrl} id="random-link" class="random-hero">
      <img id="random-image" src="" alt="Random Photography" style="opacity: 0; transition: opacity 0.5s ease-in;" />
    </a>
  </div>
</BaseLayout>

<script is:inline define:vars={{ imageUrls }}>
  // Pick a random image from the list
  if (imageUrls.length > 0) {
    const randomIndex = Math.floor(Math.random() * imageUrls.length);
    const randomUrl = imageUrls[randomIndex];
    
    const imgElement = document.getElementById('random-image');
    if (imgElement) {
      imgElement.src = randomUrl;
      imgElement.onload = () => {
        imgElement.style.opacity = '1';
      };
    }
  }
</script>

<style>
  .home {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }
  .random-hero {
    display: block;
    width: 100%;
    max-width: 1000px;
  }
  .random-hero img {
    width: 100%;
    height: auto;
    display: block;
    box-shadow: 0 4px 30px rgba(0,0,0,0.05);
  }
</style>
