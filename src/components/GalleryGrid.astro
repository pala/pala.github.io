---
interface Props {
  images: string[];
}

const { images } = Astro.props;

// For markdown relative paths like ../../assets/posts/2021-09-10-guangzhou/Guangzhou0.webp
// Astro's glob needs to be used to import them dynamically
const allAssets = import.meta.glob('/src/assets/**/*.{jpeg,jpg,png,svg,webp,JPEG,JPG,PNG,SVG,WEBP}');

const normalizePath = (p: string) => p.startsWith('/') ? p : '/' + p;

const resolvedImages = await Promise.all(
  images.map(async (src) => {
    // Convert markdown relative path (../../assets/...) to absolute src path (/src/assets/...)
    const absPath = normalizePath(src.replace('../../', 'src/'));
    
    // Find the matching key in allAssets (case-insensitive and leading-slash insensitive)
    const imageKey = Object.keys(allAssets).find(key => 
      normalizePath(key).toLowerCase() === absPath.toLowerCase()
    );

    if (imageKey) {
      const asset = await allAssets[imageKey]() as { default: { src: string } };
      return {
        src: asset.default.src,
        original: src
      };
    }
    return null;
  })
).then((urls: ({ src: string, original: string } | null)[]) => urls.filter((url): url is { src: string, original: string } => url !== null));
---

<div class="gallery-grid">
  {resolvedImages.map((img) => (
    <div class="gallery-item">
      <img 
        src={img.src} 
        alt="" 
        class="thumbnail"
      />
    </div>
  ))}
</div>

<div id="lightbox" class="lightbox">
  <span class="close">&times;</span>
  <img class="lightbox-content" id="lightbox-img">
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 10px;
    margin: 40px 0;
  }

  .gallery-item {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    cursor: pointer;
    background: #f0f0f0;
    position: relative;
  }

  .thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease, transform 0.5s ease;
  }

  .gallery-item:hover .thumbnail {
    transform: scale(1.03);
    opacity: 0.9;
  }

  /* Lightbox Styles */
  .lightbox {
    display: none;
    position: fixed;
    z-index: 2000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    cursor: zoom-out;
  }

  .lightbox-content {
    margin: auto;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 95vw;
    max-height: 95vh;
    object-fit: contain;
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translate(-50%, -48%) scale(0.98); }
    to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }

  .close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: #111;
    font-size: 30px;
    cursor: pointer;
    z-index: 2100;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.querySelector('.close');

  document.querySelectorAll('.thumbnail').forEach(item => {
    item.addEventListener('click', (e) => {
      const target = e.target as HTMLImageElement;
      if (lightbox) lightbox.style.display = "block";
      if (lightboxImg) lightboxImg.src = target.src; 
      document.body.style.overflow = 'hidden'; // Prevent scrolling
    });
  });

  const closeLightbox = () => {
    if (lightbox) lightbox.style.display = "none";
    document.body.style.overflow = 'auto';
  };

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', closeLightbox);
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
