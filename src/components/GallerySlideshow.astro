---
interface Props {
  images: string[];
}

const { images } = Astro.props;
---

<div class="slideshow-wrapper">
  <div class="slideshow-container" id="slideshow">
    {images.map((img, index) => (
      <div class={`slide ${index === 0 ? 'active' : ''}`} data-index={index}>
        <img 
          src={img} 
          alt="" 
          class="slide-image"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </div>
    ))}
  </div>

  <div class="controls">
    <button class="prev" id="prevBtn">&larr;</button>
    <div class="counter"><span id="current">1</span> / {images.length}</div>
    <button class="next" id="nextBtn">&rarr;</button>
  </div>
</div>

<style>
  .slideshow-wrapper {
    margin: 20px 0;
  }
  .slideshow-container {
    position: relative;
    width: 100%;
    height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-color);
  }

  .slide {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease-in-out, transform 0.4s ease-out;
    pointer-events: none;
    transform: scale(0.98);
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .slide-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  .controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    padding: 20px 0;
    z-index: 10;
  }

  button {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--text-color);
    padding: 5px 10px;
    transition: transform 0.2s ease;
  }

  button:hover {
    transform: scale(1.2);
  }

  .counter {
    font-size: 14px;
    color: var(--meta-color);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  let currentIndex = 0;
  const slides = document.querySelectorAll('.slide');
  const currentSpan = document.getElementById('current');
  const total = slides.length;

  const showSlide = (index: number) => {
    if (total === 0) return;
    const currentActive = slides[currentIndex];
    if (currentActive) currentActive.classList.remove('active');
    
    currentIndex = (index + total) % total;
    
    const nextActive = slides[currentIndex];
    if (nextActive) nextActive.classList.add('active');
    
    if (currentSpan) currentSpan.textContent = (currentIndex + 1).toString();
  };

  document.getElementById('prevBtn')?.addEventListener('click', () => showSlide(currentIndex - 1));
  document.getElementById('nextBtn')?.addEventListener('click', () => showSlide(currentIndex + 1));

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') showSlide(currentIndex - 1);
    if (e.key === 'ArrowRight') showSlide(currentIndex + 1);
  });

  // Simple Swipe Support
  let touchStartX = 0;
  let touchEndX = 0;
  const slideshow = document.getElementById('slideshow');

  slideshow?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  slideshow?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, { passive: true });

  const handleSwipe = () => {
    if (touchEndX < touchStartX - 50) showSlide(currentIndex + 1);
    if (touchEndX > touchStartX + 50) showSlide(currentIndex - 1);
  };
</script>
